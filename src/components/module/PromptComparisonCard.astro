---
interface Props {
  title: string;
  context?: string;
  weakPrompt: string;
  improvedPrompt: string;
  weakIssues?: string[];
  improvements?: string[];
  verification?: string[];
}

const {
  title,
  context,
  weakPrompt,
  improvedPrompt,
  weakIssues = [],
  improvements = [],
  verification = [],
} = Astro.props;

const hasWeakIssues = weakIssues.length > 0;
const hasImprovements = improvements.length > 0;
const hasVerification = verification.length > 0;
---

<article class="content-card overflow-hidden p-0">
  <div class="border-b border-slate-200 bg-slate-50/80 p-6 md:p-7">
    <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-sky-700">
          Comparación de prompt
        </p>

        <h3 class="mt-1 text-xl font-bold text-slate-900">
          {title}
        </h3>

        {context && (
          <p class="mt-3 max-w-4xl leading-7 text-slate-700">
            {context}
          </p>
        )}
      </div>

      <div class="rounded-full border border-sky-200 bg-white px-4 py-2 text-sm font-semibold text-sky-800 shadow-sm">
        Débil → Mejorado
      </div>
    </div>
  </div>

  <div class="grid gap-0 lg:grid-cols-2">
    <section class="border-b border-slate-200 p-6 md:p-7 lg:border-b-0 lg:border-r">
      <div class="mb-4 flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-rose-100 text-lg font-bold text-rose-700">
          !
        </div>

        <div>
          <h4 class="font-bold text-slate-900">Prompt débil</h4>
          <p class="text-sm text-slate-600">
            Instrucción incompleta, ambigua o difícil de revisar.
          </p>
        </div>
      </div>

      <div class="rounded-2xl border border-rose-100 bg-rose-50 p-5">
        <pre class="whitespace-pre-wrap break-words font-sans text-sm leading-7 text-slate-800"><code>{weakPrompt}</code></pre>
      </div>
    </section>

    <section class="p-6 md:p-7">
      <div class="mb-4 flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 text-lg font-bold text-emerald-700">
          ✓
        </div>

        <div>
          <h4 class="font-bold text-slate-900">Prompt mejorado</h4>
          <p class="text-sm text-slate-600">
            Instrucción con contexto, tarea, formato y criterios más claros.
          </p>
        </div>
      </div>

      <div class="rounded-2xl border border-emerald-100 bg-emerald-50 p-5">
        <pre class="whitespace-pre-wrap break-words font-sans text-sm leading-7 text-slate-800"><code>{improvedPrompt}</code></pre>
      </div>
    </section>
  </div>

  {(hasWeakIssues || hasImprovements || hasVerification) && (
    <div class="border-t border-slate-200 bg-white p-6 md:p-7">
      <h4 class="text-lg font-bold text-slate-900">
        Análisis del cambio
      </h4>

      <div class="mt-5 grid gap-5 lg:grid-cols-3">
        {hasWeakIssues && (
          <section class="rounded-2xl border border-rose-100 bg-rose-50/70 p-5">
            <p class="font-bold text-rose-900">
              Problemas del prompt inicial
            </p>

            <ul class="mt-3 space-y-3">
              {weakIssues.map((issue) => (
                <li class="flex gap-3 text-sm leading-6 text-slate-700">
                  <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-rose-100 text-xs font-bold text-rose-700">
                    !
                  </span>
                  <span>{issue}</span>
                </li>
              ))}
            </ul>
          </section>
        )}

        {hasImprovements && (
          <section class="rounded-2xl border border-sky-100 bg-sky-50/70 p-5">
            <p class="font-bold text-sky-900">
              Por qué mejora
            </p>

            <ul class="mt-3 space-y-3">
              {improvements.map((improvement) => (
                <li class="flex gap-3 text-sm leading-6 text-slate-700">
                  <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-sky-100 text-xs font-bold text-sky-700">
                    +
                  </span>
                  <span>{improvement}</span>
                </li>
              ))}
            </ul>
          </section>
        )}

        {hasVerification && (
          <section class="rounded-2xl border border-amber-100 bg-amber-50/80 p-5">
            <p class="font-bold text-amber-900">
              Qué debe verificarse
            </p>

            <ul class="mt-3 space-y-3">
              {verification.map((item) => (
                <li class="flex gap-3 text-sm leading-6 text-slate-700">
                  <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-amber-100 text-xs font-bold text-amber-700">
                    ?
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </section>
        )}
      </div>
    </div>
  )}
</article>