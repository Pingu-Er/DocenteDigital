---
interface Props {
  title: string;
  image?: string;
  imageAlt?: string;
}

const { title, image = '', imageAlt = '' } = Astro.props;
const hasImage = image && image.trim() !== '';
---

<div class="content-card overflow-hidden">
  <div class="p-5">
    <h3 class="text-lg font-bold text-slate-900">{title}</h3>
  </div>

  <div class="px-5 pb-5">
    {hasImage ? (
      <div class="flex h-56 items-center justify-center rounded-2xl bg-slate-50 p-3">
        <img
          src={image}
          alt={imageAlt || title}
          class="h-full w-full object-contain"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="placeholder-box h-56 rounded-2xl">
        Aquí puede colocar una imagen o ilustración
        <br />
        relacionada con <strong>{title}</strong>
      </div>
    )}
  </div>

  <div class="px-5 pb-5 prose-soft text-slate-700">
    <slot />
  </div>
</div>