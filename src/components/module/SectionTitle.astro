---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mb-8">
  {eyebrow && (
    <p class="mb-3 inline-block rounded-full bg-sky-100 px-3 py-1 text-sm font-semibold text-sky-700">
      {eyebrow}
    </p>
  )}
  <h2 class="text-3xl font-bold tracking-tight text-slate-900">{title}</h2>
  {description && <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">{description}</p>}
</div>