---
interface RecommendationItem {
  id: string;
  tool: string;
  title: string;
  description?: string;
  href?: string;
  label?: string;
}

interface Props {
  title?: string;
  description?: string;
  items?: RecommendationItem[];
  emptyTitle?: string;
  emptyMessage?: string;
}

const {
  title = 'Recomendaciones',
  description = 'Aquí aparecerán recursos sugeridos según tu desempeño en cada herramienta.',
  items = [],
  emptyTitle = 'Buen punto de partida',
  emptyMessage = 'Tu desempeño muestra una base funcional y técnica bastante sólida. Puedes usar recursos opcionales para seguir afinando tu trabajo.',
} = Astro.props;
---

<section class="content-card p-6">
  <div class="mb-5">
    <h3 class="text-xl font-bold text-slate-900">{title}</h3>
    <p class="mt-2 text-sm leading-7 text-slate-600">
      {description}
    </p>
  </div>

  {items.length > 0 ? (
    <div class="space-y-4">
      {items.map((item) => (
        <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
                {item.tool}
              </p>
              <h4 class="mt-3 text-base font-bold text-slate-900">
                {item.title}
              </h4>

              {item.description && (
                <p class="mt-2 text-sm leading-7 text-slate-600">
                  {item.description}
                </p>
              )}
            </div>

            {item.href && (
              <div class="shrink-0">
                <a
                  href={item.href}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex rounded-xl bg-sky-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-sky-800"
                >
                  {item.label || 'Ver recurso'}
                </a>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  ) : (
    <div class="rounded-2xl border border-emerald-200 bg-emerald-50 p-5">
      <h4 class="text-lg font-bold text-emerald-900">{emptyTitle}</h4>
      <p class="mt-2 text-sm leading-7 text-emerald-800">
        {emptyMessage}
      </p>
    </div>
  )}
</section>