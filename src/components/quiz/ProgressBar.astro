---
interface Props {
  current?: number;
  total: number;
  label?: string;
  description?: string;
}

const {
  current = 1,
  total,
  label = 'Progreso del cuestionario',
  description = 'Avance general de la evaluación',
} = Astro.props;

const safeTotal = Math.max(total, 1);
const safeCurrent = Math.min(Math.max(current, 1), safeTotal);
const percentage = Math.round((safeCurrent / safeTotal) * 100);
---

<div
  class="content-card p-5"
  data-progress-root
  aria-label={label}
>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-sky-700">
        {label}
      </p>
      <p class="mt-1 text-sm leading-6 text-slate-600" data-progress-description>
        {description}
      </p>
    </div>

    <div class="text-sm font-medium text-slate-700">
      <span data-progress-current>{safeCurrent}</span>
      <span class="mx-1 text-slate-400">/</span>
      <span data-progress-total>{safeTotal}</span>
      <span class="ml-2 text-slate-500">preguntas</span>
    </div>
  </div>

  <div class="mt-4">
    <div
      class="h-3 w-full overflow-hidden rounded-full bg-slate-200"
      role="progressbar"
      aria-valuemin="1"
      aria-valuemax={safeTotal}
      aria-valuenow={safeCurrent}
      aria-valuetext={`${safeCurrent} de ${safeTotal}`}
      data-progressbar
    >
      <div
        class="h-full rounded-full bg-sky-600 transition-all duration-300 ease-out"
        data-progress-fill
        style={`width: ${percentage}%`}
      />
    </div>

    <div class="mt-3 flex items-center justify-between text-xs font-medium text-slate-500">
      <span>Inicio</span>
      <span data-progress-percent>{percentage}% completado</span>
      <span>Final</span>
    </div>
  </div>
</div>