---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BASE_PATH } from '../consts';
---

<BaseLayout
  title="DocenteDigital | Inicio"
  description="Centro de aprendizaje digital para docentes"
>
  <section class="grid gap-10 md:grid-cols-2 md:items-center">
    <div>
      <p class="mb-3 inline-block rounded-full bg-sky-100 px-3 py-1 text-sm font-semibold text-sky-700">
        Formación digital para docentes
      </p>

      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        Aprende herramientas digitales e inteligencia artificial con claridad y propósito.
      </h1>

      <p class="mt-5 text-lg leading-8 text-slate-600">
        DocenteDigital reúne contenidos claros, visuales y útiles para fortalecer
        competencias digitales y acompañar el uso pedagógico de herramientas tecnológicas.
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href={`${BASE_PATH}/modulos/`}
          class="rounded-xl bg-sky-700 px-5 py-3 font-semibold text-white hover:bg-sky-800"
        >
          Explorar módulos
        </a>
      </div>
    </div>

    <div class="content-card p-8">
      <h2 class="text-xl font-bold text-slate-900">¿Qué encontrarás aquí?</h2>
      <ul class="mt-5 space-y-4 text-slate-700">
        <li>• Explicaciones claras y progresivas.</li>
        <li>• Ejemplos prácticos orientados al trabajo docente.</li>
        <li>• Temas organizados por módulos.</li>
        <li>• Recursos de apoyo visual y consulta sencilla.</li>
      </ul>
    </div>
  </section>
</BaseLayout>