---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopicCard from '../../components/module/TopicCard.astro';
import SectionTitle from '../../components/module/SectionTitle.astro';
import { BASE_PATH } from '../../consts';

const modules = [
  {
    title: 'Módulo 1',
    description: 'Competencias básicas de computadora orientadas a docencia.',
    href: `${BASE_PATH}/modulos/modulo-1/`,
    status: 'Disponible',
  },
];
---

<BaseLayout title="DocenteDigital | Módulos">
  <SectionTitle
    eyebrow="Ruta de aprendizaje"
    title="Módulos"
    description="Seleccione un módulo para acceder a sus temas, recursos y contenidos principales."
  />

  <section class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
    {modules.map((module) => (
      <TopicCard
        title={module.title}
        description={module.description}
        href={module.href}
        status={module.status}
      />
    ))}
  </section>
</BaseLayout>