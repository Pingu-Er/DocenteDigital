---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionTitle from '../../../components/module/SectionTitle.astro';
import InfoBox from '../../../components/module/InfoBox.astro';
import ExampleCard from '../../../components/module/ExampleCard.astro';
import HighlightMistakes from '../../../components/module/HighlightMistakes.astro';
import CommonMistakes from '../../../components/module/CommonMistakes.astro';
import VisualActionCard from '../../../components/module/VisualActionCard.astro';
import VideoCarousel from '../../../components/module/VideoCarousel.astro';
import { BASE_PATH } from '../../../consts';

const cloudBasics = [
  {
    title: '¿Qué significa guardar en la nube?',
    text: 'Guardar en la nube significa almacenar archivos en un servicio en línea en lugar de depender solo del almacenamiento local de una computadora o memoria USB.',
  },
  {
    title: '¿Para qué sirve?',
    text: 'Permite acceder a archivos desde distintos dispositivos, compartir materiales con otras personas y reducir la dependencia de tener todo guardado en un solo equipo.',
  },
  {
    title: '¿Qué se necesita?',
    text: 'Normalmente se necesita una cuenta, conexión a internet en la mayoría de los casos y un dispositivo compatible para entrar, revisar o editar archivos.',
  },
];

const providerOverview = [
  {
    title: 'Google Drive',
    image: `${BASE_PATH}/images/modulo-1/nube/google-drive.png`,
    imageAlt: 'Vista general de Google Drive',
    text: 'Drive permite guardar archivos, crear carpetas, compartir contenido y trabajar con documentos de Google como Docs, Sheets, Slides y Forms dentro del mismo entorno.',
  },
  {
    title: 'OneDrive',
    image: `${BASE_PATH}/images/modulo-1/nube/onedrive.png`,
    imageAlt: 'Vista general de OneDrive',
