---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionTitle from '../../../components/module/SectionTitle.astro';
import InfoBox from '../../../components/module/InfoBox.astro';

import ExampleCard from '../../../components/module/ExampleCard.astro';
import VisualActionCard from '../../../components/module/VisualActionCard.astro';
import HighlightMistakes from '../../../components/module/HighlightMistakes.astro';
import SimpleCarousel from '../../../components/module/SimpleCarousel.astro';
import { BASE_PATH } from '../../../consts';

const mouseMistakes = [
  'Hacer varios clics seguidos cuando solo se necesita uno.',
  'Usar doble clic en acciones que se realizan con un solo clic.',
  'Soltar el mouse antes de terminar un arrastre.',
  'Confundir el clic izquierdo con el clic derecho.',
  'Mover el mouse demasiado rápido y perder precisión.',
];

const keyboardMistakes = [
  'Escribir sin observar en qué parte está el cursor.',
  'Mantener una tecla presionada más tiempo del necesario.',
  'Confundir la tecla Enter con retroceso o eliminar.',
  'Escribir todo en mayúsculas sin intención.',
  'Borrar texto accidentalmente por no distinguir Backspace y Delete.',
];

const mouseActions = [
  {
    title: 'Clic izquierdo',
    image: `${BASE_PATH}/images/modulo-1/perifericos/Left_clic.png`,
    imageAlt: 'Imagen ilustrativa de clic izquierdo',
    text: 'Se usa para seleccionar opciones, botones, archivos o enlaces.',
    example: 'Seleccionar un archivo antes de abrirlo o moverlo.',
  },
  {
    title: 'Doble clic',
    image: `${BASE_PATH}/images/modulo-1/perifericos/Double_clic.png`,
    imageAlt: 'Imagen ilustrativa de doble clic',
    text: 'Se usa principalmente para abrir archivos, carpetas o programas.',
    example: 'Abrir una carpeta con materiales de clase.',
  },
  {
    title: 'Clic derecho',
    image: `${BASE_PATH}/images/modulo-1/perifericos/Right_clic_.png`,
    imageAlt: 'Imagen ilustrativa de clic derecho',
    text: 'Muestra opciones adicionales relacionadas con el elemento seleccionado.',
    example: 'Renombrar un archivo o ver opciones para copiarlo.',
  },
  {
    title: 'Rueda de desplazamiento',
    image: `${BASE_PATH}/images/modulo-1/perifericos/Scroll.png`,
    imageAlt: 'Imagen ilustrativa de rueda del mouse',
    text: 'Permite avanzar o retroceder dentro de una página, documento o lista.',
    example: 'Leer una planeación larga o revisar una presentación.',
  },
  {
    title: 'Arrastrar y soltar',
    image: `${BASE_PATH}/images/modulo-1/perifericos/Drag.png`,
    imageAlt: 'Imagen ilustrativa de arrastrar y soltar',
    text: 'Sirve para mover elementos de un lugar a otro.',
    example: 'Mover un archivo a una carpeta o reubicar una imagen en una diapositiva.',
  },
];

const keyboardKeys = [
  {
    title: 'Enter',
    image: `${BASE_PATH}/images/modulo-1/perifericos/Enter.png`,
    imageAlt: 'Imagen ilustrativa de la tecla Enter',
    text: 'Confirma una acción o crea una nueva línea al escribir.',
  },
  {
    title: 'Backspace',
    image: `${BASE_PATH}/images/modulo-1/perifericos/Backspace.png`,
    imageAlt: 'Imagen ilustrativa de la tecla Backspace',
    text: 'Borra el carácter anterior al cursor.',
  },
  {
    title: 'Delete',
    image: `${BASE_PATH}/images/modulo-1/perifericos/Del.png`,
    imageAlt: 'Imagen ilustrativa de la tecla Delete',
    text: 'Borra el carácter siguiente o un elemento seleccionado.',
  },
  {
    title: 'Shift',
    image: `${BASE_PATH}/images/modulo-1/perifericos/Shift.png`,
    imageAlt: 'Imagen ilustrativa de la tecla Shift',
    text: 'Sirve para escribir mayúsculas temporales y algunos símbolos.',
  },
  {
    title: 'Ctrl',
    image: `${BASE_PATH}/images/modulo-1/perifericos/Ctrl.png`,
    imageAlt: 'Imagen ilustrativa de la tecla Ctrl',
    text: 'Se usa junto con otras teclas para atajos útiles.',
  },
  {
    title: 'Tab',
    image: `${BASE_PATH}/images/modulo-1/perifericos/Tab.png`,
    imageAlt: 'Imagen ilustrativa de la tecla Tab',
    text: 'Ayuda a avanzar entre campos o zonas de trabajo.',
  },
  {
    title: 'Esc',
    image: `${BASE_PATH}/images/modulo-1/perifericos/Esc.png`,
    imageAlt: 'Imagen ilustrativa de la tecla Esc',
    text: 'Permite cancelar o salir de ciertas acciones.',
  },
  {
    title: 'Flechas',
    image: `${BASE_PATH}/images/modulo-1/perifericos/Arrows.png`,
    imageAlt: 'Imagen ilustrativa de las flechas del teclado',
    text: 'Ayudan a desplazarse dentro de textos, listas o celdas.',
  },
  {
    title: 'Barra espaciadora',
    image: `${BASE_PATH}/images/modulo-1/perifericos/Spacebar.png`,
    imageAlt: 'Imagen ilustrativa de la barra espaciadora',
    text: 'Agrega espacios entre palabras al escribir.',
  },
];

const editingShortcuts = [
  {
    image: `${BASE_PATH}/images/modulo-1/perifericos/1.png`,
    alt: 'Imagen de ejemplo para copiar con Ctrl C',
    caption: 'Ctrl + C: permite copiar texto, imágenes o archivos seleccionados para reutilizarlos en otro lugar.',
  },
  {
    image: `${BASE_PATH}/images/modulo-1/perifericos/2.png`,
    alt: 'Imagen de ejemplo para pegar con Ctrl V',
    caption: 'Ctrl + V: permite pegar lo que se ha copiado previamente en documentos, carpetas o presentaciones.',
  },
  {
    image: `${BASE_PATH}/images/modulo-1/perifericos/3.png`,
    alt: 'Imagen de ejemplo para cortar con Ctrl X',
    caption: 'Ctrl + X: sirve para mover contenido de un lugar a otro sin duplicarlo.',
  },
  {
    image: `${BASE_PATH}/images/modulo-1/perifericos/4.png`,
    alt: 'Imagen de ejemplo para deshacer con Ctrl Z',
    caption: 'Ctrl + Z: ayuda a corregir errores recientes, por ejemplo al borrar o mover algo por accidente.',
  },
];

const organizationShortcuts = [
  {
    image: `${BASE_PATH}/images/modulo-1/perifericos/5.png`,
    alt: 'Imagen de ejemplo para seleccionar todo',
    caption: 'Ctrl + A: selecciona todo el contenido de un documento o una lista.',
  },
  {
    image: `${BASE_PATH}/images/modulo-1/perifericos/6.png`,
    alt: 'Imagen de ejemplo para guardar',
    caption: 'Ctrl + S: guarda cambios en documentos, presentaciones o archivos de trabajo.',
  },
  {
    image: `${BASE_PATH}/images/modulo-1/perifericos/7.png`,
    alt: 'Imagen de ejemplo para imprimir',
    caption: 'Ctrl + P: abre la ventana de impresión en muchos programas.',
  },
  {
    image: `${BASE_PATH}/images/modulo-1/perifericos/9.png`,
    alt: 'Imagen de ejemplo para buscar',
    caption: 'Ctrl + F: ayuda a localizar palabras o datos rápidamente dentro de una página o documento.',
  },
];

const windowShortcuts = [
  {
    image: `${BASE_PATH}/images/modulo-1/perifericos/10.png`,
    alt: 'Imagen de ejemplo para cambiar entre ventanas',
    caption: 'Alt + Tab: permite cambiar entre programas abiertos sin necesidad de usar el mouse.',
  },
  {
    image: `${BASE_PATH}/images/modulo-1/perifericos/11.png`,
    alt: 'Imagen de ejemplo para abrir explorador',
    caption: 'Win + E: abre directamente el explorador de archivos para acceder a carpetas y documentos.',
  },
];
---

<BaseLayout
  title="Módulo 1 | Uso de periféricos"
  description="Teclado, mouse y atajos esenciales para un uso más seguro de la computadora."
>
  <div class="mb-8">
    <a
      href={`${BASE_PATH}/modulos/modulo-1/`}
      class="text-sm font-semibold text-sky-700 hover:text-sky-800"
    >
      ← Volver al módulo 1
    </a>
  </div>

  <SectionTitle
    eyebrow="Tema 1"
    title="Uso de periféricos"
    description="Teclado, mouse y atajos esenciales para trabajar con mayor seguridad, claridad y confianza."
  />

  <section class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
    <div class="content-card p-8 prose-soft text-slate-700">
      <p>
        El uso correcto del teclado y del mouse facilita tareas cotidianas como abrir archivos,
        escribir documentos, navegar por internet y organizar materiales de clase.
      </p>
      <p>
        En este tema se explican las funciones más útiles de estos periféricos, así como errores frecuentes
        que pueden evitarse con una mejor comprensión de su uso.
      </p>
    </div>

    <InfoBox title="Propósito del tema" tone="info">
      <p>
        Reconocer las funciones básicas del mouse y del teclado para trabajar con mayor seguridad
        en tareas digitales de uso cotidiano.
      </p>
    </InfoBox>
  </section>

  <section class="mt-14">
    <SectionTitle
      title="¿Qué son los periféricos?"
      description="Son los dispositivos que permiten interactuar con la computadora. En este tema nos enfocaremos en dos de los más importantes: el mouse y el teclado."
    />

    <div class="grid gap-6 md:grid-cols-2">
      <div class="content-card p-6">
        <h3 class="text-lg font-bold text-slate-900">Mouse</h3>
        <img
          src={`${BASE_PATH}/images/modulo-1/perifericos/mouse.png`}
          alt="Imagen general del mouse"
          class="mt-4 h-56 w-full rounded-2xl object-contain bg-slate-50 p-3"
          loading="lazy"
        />
      </div>

      <div class="content-card p-6">
        <h3 class="text-lg font-bold text-slate-900">Teclado</h3>
        <img
          src={`${BASE_PATH}/images/modulo-1/perifericos/Teclado.png`}
          alt="Imagen general del teclado"
          class="mt-4 h-56 w-full rounded-2xl object-contain bg-slate-50 p-3"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="mt-14">
    <SectionTitle
      title="Uso del mouse"
      description="El mouse permite seleccionar, abrir, mover y explorar elementos dentro de la computadora."
    />

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {mouseActions.map((action) => (
        <VisualActionCard
          title={action.title}
          image={action.image}
          imageAlt={action.imageAlt}
        >
          <p>{action.text}</p>
          <p><strong>Ejemplo práctico:</strong> {action.example}</p>
        </VisualActionCard>
      ))}
    </div>
  </section>

  <section class="mt-14">
    <SectionTitle
      title="Uso del teclado"
      description="El teclado permite escribir, corregir, desplazarse y ejecutar acciones rápidas mediante combinaciones sencillas."
    />

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {keyboardKeys.map((keyItem) => (
        <VisualActionCard
          title={keyItem.title}
          image={keyItem.image}
          imageAlt={keyItem.imageAlt}
        >
          <p>{keyItem.text}</p>
        </VisualActionCard>
      ))}
    </div>
  </section>

  <section class="mt-14">
    <SectionTitle
      title="Errores frecuentes"
      description="Estos errores son comunes y forman parte del proceso de aprendizaje. Identificarlos ayuda a corregirlos con mayor rapidez."
    />

    <div class="mb-6">
      <InfoBox title="Importante" tone="warning">
        <p>
          Muchos problemas en el uso básico de la computadora no se deben a falta de capacidad,
          sino a pequeños hábitos que pueden corregirse con práctica y atención.
        </p>
      </InfoBox>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      <HighlightMistakes title="Errores frecuentes con el mouse" mistakes={mouseMistakes} />
      <HighlightMistakes title="Errores frecuentes con el teclado" mistakes={keyboardMistakes} />
    </div>
  </section>

  <section class="mt-14">
    <SectionTitle
      title="Atajos esenciales"
      description="Los atajos permiten ahorrar tiempo en acciones que se repiten constantemente. A continuación se muestran ejemplos visuales organizados por tipo de uso."
    />

    <div class="grid gap-6 xl:grid-cols-3">
      <SimpleCarousel title="Edición básica" items={editingShortcuts} />
      <SimpleCarousel title="Organización y búsqueda" items={organizationShortcuts} />
      <SimpleCarousel title="Cambio entre ventanas" items={windowShortcuts} />
    </div>
  </section>

    <section class="mt-14">
      <SectionTitle
        title="Documento visual de atajos"
        description="Aquí puede mostrarse posteriormente un documento visual con atajos de Windows y otras combinaciones útiles de teclado para consulta dentro de la misma página."
      />

      <div class="content-card p-6">
        <div class="placeholder-box min-h-[380px]">
          Aquí se mostrará un documento visual más completo
          <br />
          con atajos de Windows y otras combinaciones útiles.
          <br /><br />
          Ruta sugerida:
          <strong>/public/docs/atajos-esenciales.pdf</strong>
        </div>

        <div class="mt-6 rounded-2xl border border-slate-200 bg-slate-50 p-5 text-slate-700">
          <p class="font-semibold text-slate-900">Cuando el documento ya exista:</p>
          <p class="mt-2 leading-7">
            puede incrustarse directamente en esta sección para que el docente lo consulte
            sin necesidad de descargarlo primero.
          </p>
        </div>
      </div>
    </section>

  <section class="mt-14">
    <InfoBox title="Cierre del tema" tone="success">
      <p>
        Dominar el uso del mouse y del teclado facilita todas las tareas posteriores del módulo.
        En el siguiente tema se trabajará la organización de archivos y carpetas, una habilidad
        clave para mantener materiales y evidencias en orden.
      </p>
    </InfoBox>
  </section>
</BaseLayout>