  },
  {
    title: 'Buscar documentos listos para consulta',
    query: 'historia de México independencia filetype:pdf',
    text: 'Sirve cuando se espera un documento más formal, por ejemplo una guía, lectura o material descargable.',
  },
  {
    title: 'Buscar en un sitio específico',
    query: 'historia de México independencia site:unam.mx',
