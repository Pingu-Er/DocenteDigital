];

const commonMistakes = [
  'Entrar al primer resultado sin revisar si era anuncio, patrocinado o una página poco clara.',
  'Buscar con palabras demasiado vagas y luego pensar que internet no muestra resultados útiles.',
  'Confiar en una sola página para temas importantes sin comparar al menos otra fuente.',
