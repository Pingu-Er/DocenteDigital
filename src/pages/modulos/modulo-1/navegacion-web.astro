  {
    title: 'Pestañas',
    image: `${BASE_PATH}/images/modulo-1/navegacion-web/pestana.png`,
    imageAlt: 'Pestañas del navegador',
    text: 'Permiten tener varias páginas abiertas al mismo tiempo. Son útiles para comparar información, dejar una fuente abierta y consultar otra sin cerrar la anterior.',
  },
  {
    title: 'Agregar a favoritos',
    image: `${BASE_PATH}/images/modulo-1/navegacion-web/favoritos.png`,
    imageAlt: 'Botón de agregar a favoritos',
    text: 'Sirve para guardar una página importante y volver a ella con más facilidad después, sin tener que buscarla nuevamente.',
