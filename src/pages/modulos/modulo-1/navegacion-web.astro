const teacherSearchExamples = [
  {
    title: 'Buscar material general para una clase',
    query: 'historia de México independencia',
    text: 'Sirve para comenzar con una búsqueda amplia y obtener páginas, imágenes, videos o recursos básicos.',
  },
  {
    title: 'Buscar imágenes para apoyar una explicación',
    query: 'historia de México independencia imágenes',
